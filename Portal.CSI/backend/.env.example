# =============================================================================
# CSI Portal — Backend Environment Configuration
# =============================================================================
# PENTING: Salin file ini menjadi .env dan isi nilai yang sesuai.
# JANGAN commit file .env ke repository.
# Semua nilai CHANGE_ME WAJIB diganti sebelum menjalankan aplikasi.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# NOTE: For IIS deployment with iisnode, comment out PORT above.
#       iisnode provides PORT automatically via named pipe.
BASE_URL=http://localhost:3000
PUBLIC_SURVEY_BASE_URL=http://localhost:3000

# ─── Database (SQL Server) ───────────────────────────────────────────────────
DB_SERVER=CHANGE_ME
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_NAME=CSI_DEV
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ─── JWT ─────────────────────────────────────────────────────────────────────
# WAJIB: Minimal 32 karakter, gunakan random string yang kuat
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_USE_RANDOM_STRING
JWT_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=7d

# ─── LDAP ────────────────────────────────────────────────────────────────────
LDAP_AUTH_URL=http://10.14.255.106:8089/LDapAuth.asmx
LDAP_TIMEOUT_MS=8000

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=CHANGE_ME
SMTP_PORT=25
SMTP_SECURE=false
SMTP_DISABLE_AUTH=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CSI Portal <noreply@component.astra.co.id>

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
SESSION_MAX_DURATION_HOURS=8

# ─── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15
LOGIN_LOCKOUT_DURATION_MINUTES=15
# Production: ganti * dengan domain spesifik, contoh: https://csi.astra.co.id
CORS_ORIGIN=*

# ─── HTTPS (production) ──────────────────────────────────────────────────────
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# ─── File Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE_MB=10

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── SAP Integration (opsional) ──────────────────────────────────────────────
SAP_API_URL=
SAP_API_KEY=
SAP_SYNC_SCHEDULE=0 2 * * *
