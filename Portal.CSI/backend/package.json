{
  "name": "csi-portal-backend",
  "version": "1.0.0",
  "description": "CSI Portal - Customer Satisfaction Index Survey Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:ci": "jest --runInBand --coverage=false --testPathIgnorePatterns=src/services/__tests__/surveyService.saveSurvey.test.js --testPathIgnorePatterns=\\.integration\\.test\\.js$ --testPathIgnorePatterns=\\.property\\.test\\.js$",
    "test:watch": "jest --watch",
    "migrate": "node src/database/migrate.js",
    "db:doctor": "node src/database/doctor.js",
    "db:audit:envs": "node scripts/audit-db-env-sync.js",
    "db:init": "node src/database/init-database.js",
    "db:seed": "node src/database/seed.js",
    "db:seed:dashboard": "node scripts/seed-dashboard-overview.js",
    "db:seed:mockup-master": "node scripts/seed-mockup-master-data.js",
    "db:seed:event-types": "node scripts/seed-event-types.js",
    "db:rollback": "node src/database/rollback.js",
    "db:backup": "node src/database/backup.js",
    "db:backup:diff": "node src/database/backup.js --differential",
    "db:backup:verify": "node src/database/restore-verify.js",
    "db:backup:list": "node src/database/restore-verify.js --list",
    "db:setup": "npm run db:init && npm run migrate && npm run db:seed",
    "db:use:show": "node scripts/switch-db-env.js --show",
    "db:use:office": "node scripts/switch-db-env.js office",
    "db:use:localdb": "node scripts/switch-db-env.js localdb"
  },
  "keywords": [
    "survey",
    "csi",
    "customer-satisfaction"
  ],
  "author": "PT Astra Otoparts Tbk",
  "license": "UNLICENSED",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.5",
    "msnodesqlv8": "^5.1.5",
    "mssql": "^12.5.5",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "fast-check": "^4.8.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "glob": "^13.0.0",
    "uuid": "^11.0.0"
  }
}
