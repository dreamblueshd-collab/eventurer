# =============================================================================
# CSI Portal — Frontend Environment Configuration
# =============================================================================
# Salin file ini menjadi .env.local dan sesuaikan nilainya.
# JANGAN commit .env.local ke repository.
# =============================================================================

# Path prefix untuk semua API call dari FE ke BE (via Next.js proxy/rewrite)
NEXT_PUBLIC_API_BASE_PATH=/api/v1

# URL internal BE — digunakan oleh Next.js server-side (bukan browser)
# Development: http://localhost:3000
# Production : sesuaikan dengan URL internal server BE
BACKEND_INTERNAL_URL=http://localhost:3000
